# Syrve
SYRVE_URL=https://half-million-co.syrve.app/dashboard/index.html#/dashboard/174327
SYRVE_USERNAME=your_username
SYRVE_PASSWORD=your_password

# Menu/report names used for navigation
SYRVE_MAIN_MENU_TEXT=Routine Restaurant Ope
SYRVE_REPORTS_SECTION_TEXT=التقارير
SYRVE_REPORT_NAME=Key Metrics

# Branches to read from Key Metrics, comma-separated
BRANCH_CODES=B60,B63,B45,B26,B105
REPORT_DATE_MODE=yesterday

# WhatsApp via your Wats API
WHATSAPP_ENABLED=true
WATS_API_URL=https://wats-enzn.onrender.com/api/v1/send
WATS_API_TOKEN=put_token_in_github_secrets_not_here
WATS_TO=9665XXXXXXXX

# Optional Email SMTP.
# EMAIL_ENABLED=true sends email every run.
# EMAIL_FALLBACK_ENABLED=true sends email only if WhatsApp fails.
EMAIL_ENABLED=false
EMAIL_FALLBACK_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=manager@example.com
